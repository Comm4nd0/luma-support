# Django
DJANGO_SECRET_KEY=change-me-in-production-use-django-secret-key-generator
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=luma_support.settings

# Database
POSTGRES_DB=luma_support
POSTGRES_USER=luma
POSTGRES_PASSWORD=luma_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (use console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=support@lumatechsolutions.co.uk
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Inbound mail (email-to-ticket). Leave INBOUND_IMAP_HOST blank to disable.
INBOUND_IMAP_HOST=
INBOUND_IMAP_PORT=993
INBOUND_IMAP_USER=
INBOUND_IMAP_PASSWORD=
INBOUND_IMAP_MAILBOX=INBOX

# Encryption (Fernet key for credentials_encrypted field).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEYS (comma-separated, primary first) is preferred and supports rotation:
#   1. Prepend a new key:    FERNET_KEYS=NEW_KEY,OLD_KEY
#   2. Re-encrypt:           python manage.py rotate_fernet_keys
#   3. Drop the old key:     FERNET_KEYS=NEW_KEY
# FERNET_KEY is the single-key legacy fallback, used when FERNET_KEYS is empty.
FERNET_KEYS=
FERNET_KEY=GENERATE_ME_WITH_FERNET_GENERATE_KEY

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Site
SITE_URL=http://localhost:8006

# Billing
DEFAULT_HOURLY_RATE=75.00
DEFAULT_CURRENCY=GBP
# UK 20% std rate. Other common: NONE (exempt), ZERORATED, EXEMPTOUTPUT.
DEFAULT_TAX_TYPE=OUTPUT2
DEFAULT_ACCOUNT_CODE=200

# Xero (https://developer.xero.com → My Apps)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8006/billing/xero/oauth/callback/
XERO_SCOPES=offline_access accounting.contacts accounting.transactions

# Stripe (https://dashboard.stripe.com → Developers → API keys / Webhooks)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
